# Copy these values into your Cloudflare Worker environment variables/secrets.
# Do NOT place the shared password into the frontend.

# Admin authentication
AUTH_SHARED_PASSWORD="change-me-to-a-long-random-password"
COOKIE_SIGNING_SECRET="change-me-to-a-long-random-secret"

# Cookie settings
COOKIE_NAME="okacephoto_admin"
COOKIE_DOMAIN=".yourdomain.com"

# CORS (frontend origin must match exactly when using cookies)
CORS_ALLOW_ORIGIN="https://app.yourdomain.com"

# Public image delivery base
# Example: https://img.yourdomain.com
R2_PUBLIC_BASE_URL="https://img.yourdomain.com"

# Upload limits
MAX_FILE_SIZE_BYTES="10485760" # 10 MiB

# Login rate limiting
LOGIN_RATE_MAX_ATTEMPTS="10"
LOGIN_RATE_WINDOW_SECONDS="600"
LOGIN_RATE_BLOCK_SECONDS="900"

# Allowed upload MIME list (comma-separated)
# Note: worker also validates magic bytes for these types.
ALLOWED_MIME="image/jpeg,image/png,image/webp,image/gif,image/svg+xml,image/avif"

